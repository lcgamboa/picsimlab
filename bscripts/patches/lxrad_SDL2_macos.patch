 /** \brief Thread Control.
@@ -42,8 +43,12 @@ protected:
   pthread_t Thread;
   int CEvent (int event);
   // wxThread *Thread;
-  bool runstate;
-  bool tdestroy;
+  /* runstate/tdestroy are written by one thread and spin-read by another
+     (Destroy: while(runstate) usleep). As plain bools the reader can spin
+     on a stale or compiler-hoisted value forever on weakly-ordered CPUs
+     (deadlocks on Apple Silicon); atomics guarantee visibility. */
+  std::atomic<bool> runstate;
+  std::atomic<bool> tdestroy;
   bool tcreated;
 public:
     CThread (void);
